# Copie para .env e ajuste os valores. O arquivo .env NÃO deve ser versionado.
POSTGRES_DB=esteticadesk_db
POSTGRES_USER=esteticadesk
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_PORT=5433
APP_PORT=8080

# Spring Boot (app fora do Compose, apontando para o Postgres do Docker)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/esteticadesk_db
SPRING_DATASOURCE_USERNAME=esteticadesk
SPRING_DATASOURCE_PASSWORD=troque-esta-senha
SERVER_PORT=8080
